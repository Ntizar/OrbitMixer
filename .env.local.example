# Public Mapbox token (safe to expose to the browser)
MAPBOX_PUBLIC_TOKEN=pk.your_mapbox_public_token

# Optional: enables real AI vision analysis via OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Optional: upgrades imagery to spectral layers via Sentinel Hub WMS
SENTINEL_HUB_INSTANCE_ID=
